{
  "name": "daleui",
  "version": "1.1.1",
  "type": "module",
  "repository": "github:DaleStudy/daleui",
  "license": "MIT",
  "homepage": "https://www.daleui.com",
  "keywords": [
    "design-system",
    "ui-components",
    "components-library",
    "react",
    "storybook"
  ],
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./*": {
      "types": "./dist/components/*/*.d.ts",
      "import": "./dist/components/*/*.js"
    }
  },
  "files": [
    "dist",
    "styled-system",
    "llms.txt",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun run generate:llms && tsc -b && vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "generate:llms": "bun scripts/generate-llms-txt.ts && bunx prettier --write --parser markdown llms.txt skills/daleui/components.md skills/daleui/tokens.md",
    "format": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "sb": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "panda codegen"
  },
  "peerDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "pretendard": "^1.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@pandacss/dev": "^1.11.4",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-designs": "^11.1.4",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-playwright": "^2.2.2",
    "chromatic": "^17.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.10"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
